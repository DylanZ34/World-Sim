graph world_map {
  layout="neato";
  overlap=false;
  splines=true;

  node [shape=circle, style=filled, fontname="Arial"];
  "city_0" [label="Hodges Capital\n(7/3)", fillcolor="#4A90D9", width=45, fontsize=10];
  "city_1" [label="Aksum Capital\n(7/4)", fillcolor="#D4A84B", width=45, fontsize=10];
  "city_2" [label="Urartu Capital\n(6/6)", fillcolor="#8B4513", width=45, fontsize=10];
  "city_3" [label="Portwatch\n(3/1)", fillcolor="#CCCCCC", width=30, fontsize=10];
  "city_4" [label="Canyonton\n(5/4)", fillcolor="#CCCCCC", width=30, fontsize=10];
  "city_5" [label="Fortton\n(6/3)", fillcolor="#CCCCCC", width=30, fontsize=10];
  "city_6" [label="Plainport\n(4/3)", fillcolor="#CCCCCC", width=30, fontsize=10];
  "city_7" [label="Riverburg\n(3/2)", fillcolor="#CCCCCC", width=30, fontsize=10];
  "city_8" [label="Plainwatch\n(4/3)", fillcolor="#CCCCCC", width=30, fontsize=10];
  "city_9" [label="Riverburg\n(4/1)", fillcolor="#CCCCCC", width=30, fontsize=10];

  "city_0" -- "city_7" [len=2];
  "city_0" -- "city_5" [len=2];
  "city_1" -- "city_8" [len=2];
  "city_1" -- "city_6" [len=2];
  "city_2" -- "city_9" [len=2];
  "city_2" -- "city_6" [len=2];
  "city_3" -- "city_5" [len=2];
  "city_3" -- "city_8" [len=2];
  "city_4" -- "city_7" [len=2];
  "city_2" -- "city_4" [len=2];
  "city_6" -- "city_8" [len=2];
  "city_6" -- "city_9" [len=2];
  "city_0" -- "city_6" [len=2];
  "city_0" -- "city_4" [len=2];
  "city_1" -- "city_7" [len=2];
  "city_2" -- "city_7" [len=2];
  "city_1" -- "city_2" [len=2];
  "city_3" -- "city_7" [len=2];
  "city_4" -- "city_8" [len=2];
  "city_4" -- "city_6" [len=2];
  "city_5" -- "city_6" [len=2];
  "city_4" -- "city_5" [len=2];
  "city_5" -- "city_7" [len=2];
  "city_5" -- "city_8" [len=2];
  "city_1" -- "city_9" [len=2];
  "city_7" -- "city_9" [len=2];
}