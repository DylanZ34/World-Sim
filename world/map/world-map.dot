graph world_map {
  layout="neato";
  overlap=false;
  splines=true;

  node [shape=circle, style=filled, fontname="Arial"];
  "city_0" [label="Hodges Capital\n(5/5)", fillcolor="#4A90D9", width=45, fontsize=10];
  "city_1" [label="Aksum Capital\n(5/4)", fillcolor="#D4A84B", width=45, fontsize=10];
  "city_2" [label="Urartu Capital\n(5/5)", fillcolor="#8B4513", width=45, fontsize=10];
  "city_3" [label="Baycrest\n(6/4)", fillcolor="#CCCCCC", width=30, fontsize=10];
  "city_4" [label="Bayton\n(5/1)", fillcolor="#CCCCCC", width=30, fontsize=10];
  "city_5" [label="Riverhold\n(5/1)", fillcolor="#CCCCCC", width=30, fontsize=10];
  "city_6" [label="Coasthaven\n(4/3)", fillcolor="#CCCCCC", width=30, fontsize=10];
  "city_7" [label="Mountainwatch\n(3/1)", fillcolor="#CCCCCC", width=30, fontsize=10];
  "city_8" [label="Canyonwatch\n(3/1)", fillcolor="#CCCCCC", width=30, fontsize=10];
  "city_9" [label="Lakeport\n(4/4)", fillcolor="#CCCCCC", width=30, fontsize=10];

  "city_0" -- "city_7" [len=2];
  "city_0" -- "city_8" [len=2];
  "city_1" -- "city_3" [len=2];
  "city_1" -- "city_9" [len=2];
  "city_2" -- "city_5" [len=2];
  "city_2" -- "city_6" [len=2];
  "city_3" -- "city_6" [len=2];
  "city_4" -- "city_7" [len=2];
  "city_4" -- "city_5" [len=2];
  "city_6" -- "city_9" [len=2];
  "city_8" -- "city_9" [len=2];
  "city_7" -- "city_8" [len=2];
  "city_0" -- "city_9" [len=2];
  "city_3" -- "city_4" [len=2];
  "city_2" -- "city_3" [len=2];
  "city_5" -- "city_8" [len=2];
  "city_1" -- "city_5" [len=2];
  "city_4" -- "city_6" [len=2];
  "city_6" -- "city_7" [len=2];
  "city_3" -- "city_8" [len=2];
}