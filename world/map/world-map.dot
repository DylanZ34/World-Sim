graph world_map {
  layout="neato";
  overlap=false;
  splines=true;

  node [shape=circle, style=filled, fontname="Arial"];
  "city_0" [label="Hodges Capital\n(5/3)", fillcolor="#4A90D9", width=45, fontsize=10];
  "city_1" [label="Aksum Capital\n(6/6)", fillcolor="#D4A84B", width=45, fontsize=10];
  "city_2" [label="Urartu Capital\n(6/4)", fillcolor="#8B4513", width=45, fontsize=10];
  "city_3" [label="Canyonvale\n(6/3)", fillcolor="#CCCCCC", width=30, fontsize=10];
  "city_4" [label="Portport\n(6/2)", fillcolor="#CCCCCC", width=30, fontsize=10];
  "city_5" [label="Porthaven\n(3/1)", fillcolor="#CCCCCC", width=30, fontsize=10];
  "city_6" [label="Mountainport\n(5/1)", fillcolor="#CCCCCC", width=30, fontsize=10];
  "city_7" [label="Valleyville\n(6/2)", fillcolor="#CCCCCC", width=30, fontsize=10];
  "city_8" [label="Canyonhold\n(3/2)", fillcolor="#CCCCCC", width=30, fontsize=10];
  "city_9" [label="Coastford\n(5/3)", fillcolor="#CCCCCC", width=30, fontsize=10];

  "city_0" -- "city_4" [len=2];
  "city_0" -- "city_9" [len=2];
  "city_1" -- "city_9" [len=2];
  "city_1" -- "city_5" [len=2];
  "city_2" -- "city_7" [len=2];
  "city_2" -- "city_3" [len=2];
  "city_3" -- "city_6" [len=2];
  "city_3" -- "city_7" [len=2];
  "city_4" -- "city_9" [len=2];
  "city_5" -- "city_9" [len=2];
  "city_6" -- "city_9" [len=2];
  "city_7" -- "city_8" [len=2];
  "city_3" -- "city_8" [len=2];
  "city_0" -- "city_1" [len=2];
  "city_1" -- "city_8" [len=2];
  "city_1" -- "city_7" [len=2];
  "city_2" -- "city_4" [len=2];
  "city_2" -- "city_5" [len=2];
  "city_6" -- "city_7" [len=2];
  "city_4" -- "city_8" [len=2];
  "city_0" -- "city_8" [len=2];
}